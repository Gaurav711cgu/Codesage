# Required for LLM-backed code review, debugging, and repository Q&A.
GEMINI_API_KEY=

# Set production values on Render. SQLite is for local development only.
ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./backend/app.db
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Local Docker Compose uses http://chromadb:8000. Production must use a
# persistent, externally reachable Chroma server URL.
CHROMADB_URL=
CHROMA_PERSIST_DIRECTORY=./backend/.chroma
CHROMA_AUTH_TOKEN=

# Optional Redis/Upstash URL. Required to share rate limits across replicas.
REDIS_URL=

# Optional GitHub API token for higher API limits during repository validation.
GITHUB_TOKEN=
