# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase PostgreSQL connection string (URI mode, asyncpg driver)
# Get from: Supabase project → Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://user:password@db.supabase.co:5432/postgres

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to true if you have Ollama running locally with the codesagez-coder model
# Run: ollama create codesagez-coder -f training/Modelfile
OLLAMA_ENABLED=false

# ChromaDB auth token (generate with: openssl rand -hex 32)
CHROMA_AUTH_TOKEN=generate_a_random_token_here

# Frontend URL (used for CORS)
# In production: your Vercel deployment URL
FRONTEND_URL=http://localhost:3000

# Environment (development | production)
ENVIRONMENT=development

# ── Frontend ──────────────────────────────────────────────────────────────────

# Backend URL for Next.js (set in Vercel dashboard for production)
NEXT_PUBLIC_API_URL=http://localhost:8000
